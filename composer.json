{
    "name": "lightpack/framework",
    "description": "LightPack - PHP MVC Framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "PHP",
        "full stack",
        "mvc",
        "database",
        "orm",
        "framework",
        "lightweight",
        "small"
    ],
    "authors": [
        {
            "name": "Pradeep Tiwari",
            "email": "pt21388@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Lightpack\\": "src/Framework"
        },
        "files": [
            "src/Framework/utilities.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Lightpack\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5.10",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.40",
        "phpmailer/phpmailer": "^6.9.2",
        "dompdf/dompdf": "^2.0",
        "twilio/sdk": "^7.0",
        "robthree/twofactorauth": "^1.8",
        "bacon/bacon-qr-code": "^3.0",
        "aws/aws-sdk-php": "^3.342",
        "resend/resend-php": "^0.22.0"
    },
    "suggest": {
        "phpmailer/phpmailer": "Required for Mailer integration (^6.9.2)",
        "dompdf/dompdf": "Required for PDF generation (^2.0)",
        "twilio/sdk": "Required for Twilio SMS integration (^7.0)",
        "robthree/twofactorauth": "Required for Two-Factor Authentication (^1.8)",
        "bacon/bacon-qr-code": "Required for server-side QR code generation (^2.0)",
        "aws/aws-sdk-php": "Required for S3Storage driver (^3.342)",
        "resend/resend-php": "Required for Resend integration (^0.22.0)"
    },
    "scripts": {
        "test": "./run-tests.sh",
        "cs": "php-cs-fixer check",
        "cs:fix": "php-cs-fixer fix",
        "stan": "phpstan analyse --no-progress",
        "qa": [
            "@test",
            "@stan",
            "@cs"
        ],
        "post-update-cmd": [
            "@composer dump-autoload"
        ]
    }
}
